{
  "name": "joanium-classic",
  "version": "2026.519.0",
  "description": "Local-first AI desktop assistant with multi-model chat, automations, agents, MCP, and real integrations. Works with Anthropic, OpenAI, Gemini, Ollama and more.",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "workspaces": [
    "Core/Electron",
    "Packages/*",
    "Packages/Capabilities/*",
    "Packages/Features/*"
  ],
  "imports": {
    "#capabilities/*": "./Packages/Capabilities/*",
    "#core/*": "./Core/*",
    "#features/*": "./Packages/Features/*",
    "#main/*": "./Packages/Main/*",
    "#modals/*": "./Packages/Modals/*",
    "#pages/*": "./Packages/Pages/*",
    "#renderer/*": "./Packages/Renderer/*",
    "#system/*": "./Packages/System/*"
  },
  "main": "App.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "version:date": "node ./Scripts/SetVersionByDate.mjs",
    "build": "node ./Scripts/Build.mjs",
    "minify:dry": "node ./Scripts/Minify.mjs --dry",
    "format": "prettier --write .",
    "lint": "eslint .",
    "packages:audit": "node ./Scripts/AuditWorkspacePackages.mjs",
    "prepare": "husky"
  },
  "keywords": [
    "joanium",
    "joanium-classic",
    "ai-assistant",
    "local-first",
    "desktop-app",
    "electron",
    "electron-app",
    "ai-desktop",
    "ai-agent",
    "automation",
    "mcp",
    "model-context-protocol",
    "multi-model",
    "ollama",
    "anthropic",
    "openai",
    "gemini",
    "agentic-ai",
    "productivity",
    "chatbot",
    "ai-workflow",
    "github-integration",
    "gmail-integration",
    "scheduled-agents",
    "personas",
    "skills",
    "offline-ai",
    "privacy-first"
  ],
  "author": "Joel Jolly",
  "license": "Apache-2.0",
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "electron-log": "5.4.4",
    "electron-updater": "6.8.3",
    "exceljs": "^4.4.0",
    "jszip": "^3.10.1",
    "mammoth": "^1.12.0",
    "pdf-parse": "^2.4.5"
  },
  "devDependencies": {
    "clean-css": "5.3.3",
    "electron": "42.2.0",
    "electron-builder": "^26.11.0",
    "eslint": "10.4.0",
    "eslint-plugin-unused-imports": "4.4.1",
    "html-minifier-terser": "7.2.0",
    "husky": "9.1.7",
    "jest": "30.4.2",
    "lint-staged": "17.0.5",
    "prettier": "3.8.3",
    "terser": "5.47.1"
  }
}
